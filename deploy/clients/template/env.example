# Variáveis de ambiente — template implantação
# Copiar para painel Netlify do site do cliente. NUNCA commitar valores reais.

# Supabase (obrigatório em produção)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Provider
DATA_PROVIDER=supabase
NEXT_PUBLIC_DATA_PROVIDER=supabase

# URL pública (canonical, WhatsApp, OG)
NEXT_PUBLIC_SITE_URL=https://seu-dominio.com.br

# Onboarding — desligar após go-live estável
# ENABLE_MIGRATION_TOOLS=true

# Opcional — rastreio futuro
# CORE_VERSION=1.0.0

# Auth Supabase: sign-ups desabilitados; admin com app_metadata.role=admin
