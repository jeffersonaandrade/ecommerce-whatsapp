# Copiar para deploy/clients/unitsports/.env.local (gitignored)
# Ativar: npm run env:use -- unitsports
# Valores reais APENAS no .env.local ou painel Netlify — NUNCA commitar

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

DATA_PROVIDER=supabase
NEXT_PUBLIC_DATA_PROVIDER=supabase

# URL pública (canonical, WhatsApp, OG)
NEXT_PUBLIC_SITE_URL=

# Base URL para smoke/E2E — ex.: https://unitsports.netlify.app
QA_BASE_URL=
