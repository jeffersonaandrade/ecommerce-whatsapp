# Env — UnitSports (placeholders)
# Valores reais APENAS no painel Netlify / .env.local — NUNCA commitar

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

DATA_PROVIDER=supabase
NEXT_PUBLIC_DATA_PROVIDER=supabase

# true durante onboarding (Import CSV + Central de Mídia); false após go-live estável
ENABLE_MIGRATION_TOOLS=

# URL pública (canonical, WhatsApp, OG)
NEXT_PUBLIC_SITE_URL=

# Base URL para smoke/E2E — ex.: https://loja-whats.netlify.app (definir no ambiente de QA)
QA_BASE_URL=
